# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://rag_user:rag_password@localhost:5432/ga4gh_rag

# ── Retrieval config ──────────────────────────────────────────────────────────
RRF_LEXICAL_WEIGHT=0.4
RRF_K=60
RETRIEVAL_TOP_K=5

# ── Model config ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072
ANALYSIS_MODEL=claude-sonnet-4-6
PREPROCESSING_MODEL=claude-haiku-4-5-20251001

# ── App config ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
LOG_LEVEL=INFO
